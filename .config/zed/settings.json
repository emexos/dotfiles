// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ui_font_weight": 100.0,
  "buffer_line_height": "standard",
  "buffer_font_weight": 100.0,
  "agent": {
    "button": false,
    "favorite_models": [],
    "model_parameters": []
  },
  "collaboration_panel": {
    "button": false
  },
  "notification_panel": {
    "button": false
  },
  "debugger": {
    "button": false
  },
  "search": {
    "button": false
  },
  "diagnostics": {
    "button": false
  },
  "terminal": {
    "font_family": "Departure Mono",
    "font_weight": 100.0,
    "button": false
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_language_button": true
  },
  "edit_predictions": {
    "provider": "none",
  },
  "git_panel": {
    "button": false,
  },
  "outline_panel": {
    "auto_fold_dirs": false,
    "folder_icons": true,
    "button": false,
    "git_status": false,
  },
  "project_panel": {
    "show_diagnostics": "off",
    "hide_root": false,
    "bold_folder_labels": false,
    "auto_fold_dirs": false,
    "folder_icons": false,
    "diagnostic_badges": false,
    "button": true,
    "git_status": true,
  },
  "tabs": {
    "git_status": false,
  },
  "file_finder": {
    "git_status": true,
  },
  "auto_update_extensions": {
    "assembly": false,
    "html": false,
    "nvim-nightfox": false,
  },
  "icon_theme": "Ton Dark Theme",
  "vim_mode": false,
  "base_keymap": "VSCode",
  "ui_font_family": "Departure Mono",
  "buffer_font_family": "Departure Mono",
  //"ui_font_family": "GohuFont",
  //"buffer_font_family": "GohuFont",
  //"ui_font_family": "Geneva",
  //"buffer_font_family": "Hack Nerd Font Mono",
  "ui_font_size": 18,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    //"dark": "Base16 Gruvbox dark, medium"
    //"dark": "Base16 Everforest"
    //"dark": "Base16 Eighties"
    //"dark": "Snazzy Theme - blurred"
    //"dark": "Snazzy Theme"
    //"dark": "One Dark"
    "dark": "emex' monochrome theme",
  },
  "workbench.status_bar.visible": false,
  "workbench.activity_bar.visible": false,
  "workbench.title_bar.visible": false,
  "editor.minimap.enabled": false,
  "toolbar": {
    "agent_review": false,
    "selections_menu": false,
    "quick_actions": false,
    "breadcrumbs": true,
    "visible": false,
  },
}
